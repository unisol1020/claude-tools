{
  "$schema": "https://raw.githubusercontent.com/manaflow-ai/cmux/main/web/data/cmux.schema.json",
  "schemaVersion": 1,
  "app": {
    "preferredEditor": "__HOME__/.config/cmux/open-in-micro.sh",
    "openSupportedFilesInCmux": false,
    "openMarkdownInCmuxViewer": true,
    "minimalMode": true,
    "warnBeforeClosingTab": false
  },
  "sidebar": {
    "hideAllDetails": false,
    "showLog": true,
    "showProgress": true
  },
  "sidebarAppearance": {
    "matchTerminalBackground": true
  },
  "terminal": {
    "showScrollBar": false
  },
  "fileExplorer": {
    "doubleClickAction": "preferredEditor"
  },
  "shortcuts": {
    "bindings": {
      "switchRightSidebarToDock": "cmd+shift+g"
    }
  },
  "browser": {
    "openTerminalLinksInCmuxBrowser": true,
    "interceptTerminalOpenCommandInCmuxBrowser": true,
    "openPortLinksInCmuxBrowser": true,
    "openPullRequestLinksInCmuxBrowser": true
  },
  "newWorkspaceCommand": "claude"
}
