# cmux terminal rendering (Ghostty) — transparent + blurred + modern
# Lives at ~/.config/ghostty/config. Reload after edits: cmux reload-config  (or Cmd+Shift+,)

# Theme — auto-switches with macOS light/dark appearance
theme = light:Catppuccin Latte,dark:Catppuccin Mocha

# Transparency + blur (the modern glass look)
background-opacity = 0.92
background-blur = 20
unfocused-split-opacity = 0.85

# Font
font-family = "JetBrainsMono Nerd Font"
font-size = 14
font-thicken = true

# Minimal, roomy chrome
window-padding-x = 14
window-padding-y = 12
window-padding-balance = true
window-padding-color = background
cursor-style = bar
cursor-style-blink = false
mouse-hide-while-typing = true
